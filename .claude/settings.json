{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-commit 1>&2 || exit 2",
            "if": "Bash(git commit*)",
            "timeout": 600,
            "statusMessage": "Running pre-commit static checks"
          }
        ]
      }
    ]
  }
}
